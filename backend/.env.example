DATABASE_URL=postgresql://pqc_user:pqc_pass@localhost:5432/pqc_platform
REDIS_URL=redis://localhost:6379/0

# ── Git Provider Tokens ────────────────────────────────────────────────
# GitHub: Settings → Developer Settings → Personal Access Tokens
# Scopes needed: repo (for private), read:org (for org repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitLab: Settings → Access Tokens → read_repository scope
GITLAB_TOKEN=glpat_xxxxxxxxxxxxxxxxxxxx

# Bitbucket: Settings → App Passwords → Repositories:Read
# Format must be username:app_password
BITBUCKET_TOKEN=myusername:xxxxxxxxxxxxxxxxxxxx

# Self-hosted Gitea
GITEA_TOKEN=xxxxxxxxxxxxxxxxxxxx

# SSH key alternative (path inside container)
SSH_KEY_PATH=/run/secrets/id_rsa

SECRET_KEY=change-me-in-production
